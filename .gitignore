# ========================
# ENVIRONMENT VARIABLES
# ========================
# Ignore all .env files anywhere in the project
**/.env
**/.env.*
!**/.env.example
# Python
**/venv/
**/__pycache__/
**/*.pyc
**/*.pyo
**/*.pyd
**/.env
**/.pytest_cache/
**/coverage/
**/.coverage

# ========================
# PYTHON (Backend)
# ========================
# Virtual Environments
**/venv/
**/env/
**/.venv/

# Cache and Bytecode
__pycache__/
*.py[cod]
*$py.class
*.so
.pytest_cache/
.coverage
coverage/

# Data & User Uploads (Prevents uploading sensitive files)
**/uploads/
*.sqlite3
*.db
*.xlsx
*.csv

# ========================
# NODE.JS (Frontend)
# ========================
**/node_modules/
**/dist/
**/dist-ssr/
**/build/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ========================
# IDEs & OS FILES
# ========================
.DS_Store
.vscode/
!.vscode/extensions.json
.idea/
*.swp
*.bak
